&GLOBAL
  PROJECT single_vacancy_sanity_bs_smear_geo_opt
  RUN_TYPE GEO_OPT
  PRINT_LEVEL LOW
&END GLOBAL
&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME /opt/cp2k_sanity/env/share/cp2k/data/BASIS_MOLOPT
    POTENTIAL_FILE_NAME /opt/cp2k_sanity/env/share/cp2k/data/GTH_POTENTIALS
    CHARGE 0
    MULTIPLICITY 3
    LSD
    &MGRID
      CUTOFF 150
      REL_CUTOFF 30
    &END MGRID
    &SCF
      EPS_SCF 5.0E-6
      MAX_SCF 500
      SCF_GUESS ATOMIC
      ADDED_MOS 80
      &SMEAR ON
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE 500
      &END SMEAR
      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA 0.20
        NBUFFER 8
      &END MIXING
      &OUTER_SCF
        MAX_SCF 20
      &END OUTER_SCF
    &END SCF
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
      &VDW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
          TYPE DFTD3(BJ)
          PARAMETER_FILE_NAME /opt/cp2k_sanity/env/share/cp2k/data/dftd3.dat
          REFERENCE_FUNCTIONAL PBE
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
    &END XC
    &POISSON
      PERIODIC XYZ
    &END POISSON
  &END DFT
  &SUBSYS
    &CELL
      A 14.75707288 0.00000000 0.00000000
      B 0.00000000 25.56000000 0.00000000
      C 0.00000000 0.00000000 24.00000000
      PERIODIC XYZ
    &END CELL
