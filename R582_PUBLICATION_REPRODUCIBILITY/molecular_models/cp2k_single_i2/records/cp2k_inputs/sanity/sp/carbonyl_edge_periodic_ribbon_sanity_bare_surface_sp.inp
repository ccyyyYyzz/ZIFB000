&GLOBAL
  PROJECT carbonyl_edge_periodic_ribbon_sanity_bare_surface_sp
  RUN_TYPE ENERGY
  PRINT_LEVEL LOW
&END GLOBAL
&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME /opt/cp2k_sanity/env/share/cp2k/data/BASIS_MOLOPT
    POTENTIAL_FILE_NAME /opt/cp2k_sanity/env/share/cp2k/data/GTH_POTENTIALS
    CHARGE 0
    MULTIPLICITY 2
    LSD
    &MGRID
      CUTOFF 150
      REL_CUTOFF 30
    &END MGRID
    &SCF
      EPS_SCF 1.0E-5
      MAX_SCF 260
      SCF_GUESS ATOMIC
      &OT
        PRECONDITIONER FULL_SINGLE_INVERSE
        MINIMIZER DIIS
      &END OT
      &OUTER_SCF
        MAX_SCF 10
      &END OUTER_SCF
    &END SCF
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
      &VDW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
          TYPE DFTD3(BJ)
          PARAMETER_FILE_NAME /opt/cp2k_sanity/env/share/cp2k/data/dftd3.dat
          REFERENCE_FUNCTIONAL PBE
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
    &END XC
    &POISSON
      PERIODIC XYZ
    &END POISSON
    &PRINT
      &MULLIKEN ON
      &END MULLIKEN
      &HIRSHFELD ON
        SELF_CONSISTENT T
      &END HIRSHFELD
      &PDOS ON
        COMPONENTS T
        NLUMO 40
        COMMON_ITERATION_LEVELS 0
      &END PDOS
    &END PRINT
  &END DFT
  &SUBSYS
    &CELL
